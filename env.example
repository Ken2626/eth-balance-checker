# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# RPC API configuration (e.g., Gnosis Chain)
RPC_URL=https://rpc.gnosischain.com/

# Telegram Bot configuration
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Target Addresses Configuration (Comma separated without spaces)
ETHEREUM_ADDRESSES=0xb56842235F1D1D327f38D96C92De82812CF5a7B8,0xE92f45287BA17765b992456af1Aa9F7913e5320d

# Token Configuration (Comma separated)
COINS_LIST=XDAI,SDAI,GNO

# Polling Interval (in seconds)
CHECKING_INTERVAL=86400

# Logging Level
LOG_LEVEL=INFO
